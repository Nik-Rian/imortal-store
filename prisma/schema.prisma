generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String
  price       Int
  images      String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}